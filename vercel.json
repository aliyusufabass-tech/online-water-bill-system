{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd waterbill/frontend && npm install",
  "buildCommand": "cd waterbill/frontend && npm run build",
  "outputDirectory": "waterbill/frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://online-water-bill-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
